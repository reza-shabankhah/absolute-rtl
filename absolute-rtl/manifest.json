{
  "manifest_version": 3,
  "name": "AbsoluteRTL",
  "version": "0.96",
  "description": "Context-aware deterministic layout engine with GUI.",
  "permissions": ["activeTab", "storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "absolute-rtl@rezashabankhah.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*", "https://aistudio.google.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "toggle-rtl-engine": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Toggle RTL Mode"
    }
  }
}