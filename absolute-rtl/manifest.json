{
  "manifest_version": 3,
  "name": "AbsoluteRTL",
  "version": "1.0.5",
  "description": "An offline, on-demand browser extension for RTL rendering in data-sensitive AI workflows.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{a23e98b1-4c65-4f2d-8e9a-1b3c5d7f6a8e}",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.woff2"
      ],
      "matches": [
        "https://gemini.google.com/*"
      ]
    }
  ],
  "commands": {
    "toggle-rtl-engine": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Toggle RTL Mode"
    }
  }
}